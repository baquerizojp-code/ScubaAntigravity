# ------------------------------------------------------------------
# Vite (current framework)
# ------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id-here
VITE_SENTRY_DSN=your_sentry_dsn_here
VITE_POSTHOG_KEY=your_posthog_key_here
VITE_POSTHOG_HOST=https://app.posthog.com

# ------------------------------------------------------------------
# Next.js (migration in progress — put these in .env.local, not .env)
# Both sets coexist through Phase F. Phase G removes the VITE_* set.
# ------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key-here
NEXT_PUBLIC_SUPABASE_PROJECT_ID=your-project-id-here
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
